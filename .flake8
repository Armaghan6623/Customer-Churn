[flake8]
max-line-length = 88
extend-ignore = E501, W503, E203
exclude =
    .git,
    .github,
    venv,
    .venv,
    __pycache__,
    *.egg-info,
    .pytest_cache,
    .mypy_cache,
    build,
    dist,
    customer crunch/saved_models,
    customer crunch/data
per-file-ignores =
    __init__.py:F401
max-complexity = 12
count = True
statistics = True
show-source = True
